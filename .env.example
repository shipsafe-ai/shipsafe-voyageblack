# VoyageBlack environment variables
# Copy to .env for local development — never commit .env

# Elasticsearch (Serverless or 9.x)
ELASTIC_CLOUD_URL=https://your-project.es.us-central1.gcp.cloud.es.io
ELASTIC_API_KEY=your_api_key_with_feature_agentBuilder_read_privilege

# Agent Builder MCP endpoint (from Kibana → Agent Builder → Tools → Manage MCP)
ELASTIC_MCP_URL=https://your-project.es.us-central1.gcp.cloud.es.io/_kibana/mcp

# Standalone ES MCP HTTP endpoint (Cloud Run service — leave empty for Docker stdio locally)
ELASTIC_ES_MCP_URL=

# Gemini via Vertex AI
GEMINI_MODEL=gemini-2.5-flash
GCP_PROJECT=shipsafe-ai
GCP_REGION=us-central1

# OTel (optional)
PHOENIX_API_KEY=
DT_ENVIRONMENT=
DT_OTLP_TOKEN=
